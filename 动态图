<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <title>高级质感星轨动画</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #050814; }
        canvas { display: block; width: 100vw; height: 100vh; }
    </style>
</head>
<body>
    <canvas id="galaxyCanvas"></canvas>
    <script>
        const canvas = document.getElementById('galaxyCanvas');
        const ctx = canvas.getContext('2d');
        
        let width, height, centerX, centerY;
        
        function resize() {
            width = canvas.width = window.innerWidth;
            height = canvas.height = window.innerHeight;
            centerX = width / 2;
            centerY = height / 2;
        }
        window.addEventListener('resize', resize);
        resize();

        // 配色方案：金、冷蓝、珍珠白
        const colors = ['#E5B76B', '#8CA8FF', '#E2E8F0'];

        // 星体类
        class Planet {
            constructor(orbitRadiusX, orbitRadiusY, tiltAngle, speed, color, size) {
                this.orbitRadiusX = orbitRadiusX;
                this.orbitRadiusY = orbitRadiusY;
                this.tiltAngle = tiltAngle; // 轨道的倾斜度
                this.speed = speed;
                this.color = color;
                this.baseSize = size;
                this.angle = Math.random() * Math.PI * 2; // 初始位置
            }

            update() {
                this.angle += this.speed;
                
                // 计算在扁平椭圆上的 2D 坐标
                let flatX = Math.cos(this.angle) * this.orbitRadiusX;
                let flatZ = Math.sin(this.angle) * this.orbitRadiusY;

                // 应用 X 轴倾斜 (绕X轴旋转) 来模拟 3D 俯视感
                this.y = flatZ * Math.sin(this.tiltAngle);
                this.z = flatZ * Math.cos(this.tiltAngle);
                this.x = flatX;

                // 简单的透视投影
                const focalLength = 800;
                this.scale = focalLength / (focalLength + this.z);
                
                this.screenX = centerX + this.x * this.scale;
                this.screenY = centerY + this.y * this.scale;
            }

            draw(ctx) {
                // 根据距离变暗和变小
                const alpha = Math.max(0.1, this.scale * 0.8);
                const currentSize = Math.max(0.1, this.baseSize * this.scale);

                ctx.save();
                ctx.globalAlpha = alpha;
                ctx.fillStyle = this.color;
                
                // 发光质感
                ctx.shadowBlur = 15 * this.scale;
                ctx.shadowColor = this.color;
                
                ctx.beginPath();
                ctx.arc(this.screenX, this.screenY, currentSize, 0, Math.PI * 2);
                ctx.fill();
                ctx.restore();
            }
        }

        // 生成多个轨道的星体
        const planets = [];
        const numOrbits = 6;
        for (let i = 0; i < numOrbits; i++) {
            // 错落有致的轨道大小和倾斜角
            let rX = 150 + i * 60;
            let rY = 100 + i * 40;
            let tilt = (Math.PI / 3) + (Math.random() * 0.4 - 0.2); // 大约 60 度倾斜
            
            // 每条轨道上放 1-3 个球
            let ballsInOrbit = Math.floor(Math.random() * 3) + 1;
            for(let j = 0; j < ballsInOrbit; j++) {
                let speed = (0.002 + Math.random() * 0.003) * (i % 2 === 0 ? 1 : -1); // 顺逆时针交替
                let color = colors[Math.floor(Math.random() * colors.length)];
                let size = 2 + Math.random() * 2.5;
                planets.push(new Planet(rX, rY, tilt, speed, color, size));
            }
        }

        function animate() {
            // 【核心秘诀1】：不要 clearRect，用带透明度的深色覆盖，形成拖尾（运动余晖）
            ctx.fillStyle = 'rgba(5, 8, 20, 0.15)'; 
            ctx.fillRect(0, 0, width, height);

            // 【核心秘诀2】：绘制极其微弱的静态轨道线（可选）
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.03)';
            ctx.lineWidth = 1;
            /* 如果需要画出实体轨道线，可以在这里加绘制逻辑，但通常只保留拖尾会更有高级感 */

            // 更新坐标
            planets.forEach(p => p.update());

            // 【核心秘诀3】：按 Z 轴深度排序 (Z-Sorting)，远的先画，近的后画
            planets.sort((a, b) => b.z - a.z);

            // 绘制星体
            planets.forEach(p => p.draw(ctx));

            requestAnimationFrame(animate);
        }

        animate();
    </script>
</body>
</html>